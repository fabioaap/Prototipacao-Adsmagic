{
  "name": "prototipacao-adsmagic",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n WORKSPACE,DOCS -c blue,cyan \"npm run dev:workspace\" \"npm run docs:dev\"",
    "dev:workspace": "vite",
    "dev:fo": "npm run dev --prefix apps/plataforma",
    "lps:install": "npm install --prefix apps/landing-pages",
    "lps:dev": "npm run dev --prefix apps/landing-pages",
    "lps:build": "npm run build --prefix apps/landing-pages",
    "lps:preview": "npm run preview --prefix apps/landing-pages",
    "lps:package": "npm run package --prefix apps/landing-pages",
    "predev:all": "node -e \"console.log('dev:all usa a primeira porta livre entre 3000 e 3006')\"",
    "dev:all": "concurrently --kill-others-on-fail -n ROOT,PLATAFORMA -c blue,green \"vite\" \"npm run dev --prefix apps/plataforma\"",
    "docs:install": "npm install --prefix workspace/docs",
    "docs:dev": "npm run start --prefix workspace/docs -- --port 3001 --host 0.0.0.0",
    "docs:build": "npm run build --prefix workspace/docs",
    "docs:serve": "npm run serve --prefix workspace/docs",
    "docs:clear": "npm run clear --prefix workspace/docs",
    "dev:with-docs": "npm run dev",
    "build:workspace": "vite build",
    "build:pages": "node ./build-pages.mjs",
    "build": "npm run build:pages",
    "preview": "vite preview",
    "gen:ads": "node scripts/generate-ads-top5.mjs"
  },
  "dependencies": {
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "vite": "^7.3.1"
  }
}
