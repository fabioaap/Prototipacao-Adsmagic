# ============================================================================
# Variáveis de Ambiente - AdsMagic Frontend
# ============================================================================
# 
# Este arquivo documenta todas as variáveis de ambiente necessárias.
#
# Para desenvolvimento: copie para .env.local e preencha
# Para producao local: copie para .env.production.local e preencha
# Para deploy remoto: configure no Cloudflare Pages Dashboard
#
# IMPORTANTE: Arquivos *.local ja estao no .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (Obrigatórias)
# ----------------------------------------------------------------------------
# URL do projeto Supabase
# Obtenha em: https://supabase.com/dashboard/project/[seu-projeto]/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima (pública) do Supabase
# Segura para uso no front-end, não é um secret
# Obtenha em: https://supabase.com/dashboard/project/[seu-projeto]/settings/api
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ----------------------------------------------------------------------------
# API (Opcional - tem fallback)
# ----------------------------------------------------------------------------
# URL base da API backend
# Se não definida, usa: https://[seu-projeto].supabase.co/functions/v1
# VITE_API_BASE_URL=https://api.exemplo.com

# ----------------------------------------------------------------------------
# FEATURE FLAGS (Opcionais)
# ----------------------------------------------------------------------------
# Usar mock para queue de jobs (true/false)
# VITE_USE_MOCK_QUEUE=false

# Habilitar polling de jobs (true/false, default: true)
# VITE_ENABLE_JOB_POLLING=true

# Intervalo de polling em milissegundos (default: 3000)
# VITE_JOB_POLLING_INTERVAL=3000

# ----------------------------------------------------------------------------
# OAUTH - CLIENT IDs (Opcionais)
# ----------------------------------------------------------------------------
# Client IDs das plataformas OAuth
# Obtenha em cada plataforma:
# - Meta: https://developers.facebook.com/apps/
# - Google: https://console.cloud.google.com/apis/credentials
# - TikTok: https://ads.tiktok.com/marketing_api/docs
# - LinkedIn: https://www.linkedin.com/developers/apps

# Meta/Facebook OAuth Client ID
# VITE_META_CLIENT_ID=seu_meta_client_id

# Google OAuth Client ID
# VITE_GOOGLE_CLIENT_ID=seu_google_client_id

# TikTok OAuth Client ID
# VITE_TIKTOK_CLIENT_ID=seu_tiktok_client_id

# LinkedIn OAuth Client ID
# VITE_LINKEDIN_CLIENT_ID=seu_linkedin_client_id

# ----------------------------------------------------------------------------
# POSTHOG - Product Analytics (Opcional)
# ----------------------------------------------------------------------------
# Project API key do PostHog Cloud
# Obtenha em: https://us.posthog.com/settings/project
# VITE_POSTHOG_KEY=phc_xxx

# ============================================================================
# NOTAS
# ============================================================================
# 
# 1. Variáveis obrigatórias devem ser preenchidas para o app funcionar
# 2. Variáveis opcionais têm valores padrão ou fallbacks no código
# 3. Para produção no Cloudflare Pages, configure estas variáveis no dashboard:
#    Dashboard → Pages → [Seu Projeto] → Settings → Environment variables
# 4. Nunca commite valores reais de secrets ou tokens
# ============================================================================
