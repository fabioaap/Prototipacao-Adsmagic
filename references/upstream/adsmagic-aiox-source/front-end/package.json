{
  "name": "front-end",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:temp": "vite build",
    "build:visual": "vite build --mode test",
    "preview": "vite preview",
    "figma:capture:localhost": "node ../scripts/figma_capture_localhost.cjs",
    "figma:select": "node ../scripts/figma_capture_localhost.cjs --open auto",
    "figma:capture:guarded": "node ../scripts/figma_capture_guarded.cjs",
    "test:ds-gate": "bash ../scripts/check-ds-gate.sh",
    "test": "vitest --exclude tests/e2e/** --exclude playwright-validation.spec.ts",
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:integration": "playwright test --config=playwright.integration.config.ts",
    "test:integration:report": "playwright show-report playwright-integration-report",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:visual": "pnpm build:visual && vite preview --port 4173 --strictPort",
    "test:visual:ci": "pnpm build:visual && pnpm exec playwright test --config=playwright.ci.config.ts",
    "sitemap:capture": "playwright test --config=playwright.sitemap.config.ts",
    "sitemap:sync": "node ../scripts/sitemap-sync.cjs",
    "sitemap:sync:dry": "node ../scripts/sitemap-sync.cjs --dry-run",
    "sitemap:coverage": "node ../scripts/sitemap-sync.cjs --coverage",
    "deploy": "pnpm build && wrangler pages deploy dist",
    "deploy:preview": "pnpm build && wrangler pages deploy dist --branch=preview",
    "deploy:production": "pnpm build && wrangler pages deploy dist --branch=main",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@internationalized/date": "^3.10.1",
    "@supabase/supabase-js": "^2.76.1",
    "@types/dompurify": "^3.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/sortablejs": "^1.15.9",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^13.9.0",
    "apexcharts": "^5.3.5",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.0",
    "html2canvas": "^1.4.1",
    "lucide-vue-next": "^0.546.0",
    "mermaid": "^11.13.0",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.6.1",
    "sortablejs": "^1.15.6",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.22",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.3",
    "vue3-apexcharts": "^1.10.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@dagrejs/dagre": "^2.0.4",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-a11y": "^10.2.14",
    "@storybook/addon-docs": "^10.2.14",
    "@storybook/vue3-vite": "^10.2.14",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/browser": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.27",
    "axe-playwright": "^2.2.2",
    "happy-dom": "^20.8.3",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "shadcn-vue": "^2.4.3",
    "storybook": "^10.2.14",
    "tailwindcss": "3.4.18",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.3"
  }
}