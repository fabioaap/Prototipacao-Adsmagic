## 5. Error Handling

### Estratégias de Erro

#### Try-Catch Específico
```typescript
// ✅ BOM - Trate erros específicos
try {
  await processPayment(amount)
} catch (error) {
  if (error instanceof PaymentDeclinedError) {
    notify('Pagamento recusado')
  } else if (error instanceof NetworkError) {
    notify('Erro de conexão')
  } else {
    logger.error('Erro inesperado', error)
    throw error
  }
}
```

#### Custom Errors
```typescript
// ✅ BOM - Crie erros customizados
class ValidationError extends Error {
  constructor(
    message: string,
    public field: string,
    public code: string
  ) {
    super(message)
    this.name = 'ValidationError'
  }
}

class NotFoundError extends Error {
  constructor(entity: string, id: string) {
    super(`${entity} with id ${id} not found`)
    this.name = 'NotFoundError'
  }
}
```

#### Result Type Pattern
```typescript
// ✅ EXCELENTE - Use Result type para operações que podem falhar
type Success<T> = { ok: true; value: T }
type Failure<E> = { ok: false; error: E }
type Result<T, E = Error> = Success<T> | Failure<E>

function divide(a: number, b: number): Result<number> {
  if (b === 0) {
    return { ok: false, error: new Error('Division by zero') }
  }
  return { ok: true, value: a / b }
}

const result = divide(10, 2)
if (result.ok) {
  console.log(result.value) // TypeScript sabe que é number
} else {
  console.error(result.error) // TypeScript sabe que é Error
}
```

