## 6. Performance

### Otimizações Gerais

#### Evite Operações Desnecessárias
```typescript
// ❌ EVITAR
function processUsers(users: User[]) {
  users.forEach(user => {
    const formatted = formatUser(user) // Formata mesmo que não use
    if (user.active) {
      save(formatted)
    }
  })
}

// ✅ BOM
function processUsers(users: User[]) {
  users
    .filter(user => user.active)
    .map(formatUser)
    .forEach(save)
}
```

#### Memoization
```typescript
// ✅ BOM - Cache cálculos caros
const expensiveCalculation = memoize((n: number) => {
  // Cálculo pesado
  return result
})
```

#### Lazy Loading
```typescript
// ✅ BOM - Carregue apenas quando necessário
class DataService {
  private _cache: Map<string, Data> | null = null
  
  private get cache(): Map<string, Data> {
    if (!this._cache) {
      this._cache = new Map()
    }
    return this._cache
  }
}
```

### Async/Await

#### Operações Paralelas
```typescript
// ❌ EVITAR - Sequential
const user = await getUser()
const posts = await getPosts()
const comments = await getComments()

// ✅ BOM - Parallel
const [user, posts, comments] = await Promise.all([
  getUser(),
  getPosts(),
  getComments()
])
```

#### Error Handling em Parallel
```typescript
// ✅ BOM - Handle errors individuais
const results = await Promise.allSettled([
  fetchUser(),
  fetchPosts(),
  fetchComments()
])

results.forEach((result, index) => {
  if (result.status === 'fulfilled') {
    console.log(`Success ${index}:`, result.value)
  } else {
    console.error(`Failed ${index}:`, result.reason)
  }
})
```

