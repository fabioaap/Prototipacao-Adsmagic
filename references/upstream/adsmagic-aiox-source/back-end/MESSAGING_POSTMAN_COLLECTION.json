						},
						"url": {
							"raw": "{{functions_url}}/messaging/webhook",
							"host": [
								"{{functions_url}}"
							],
							"path": [
								"messaging",
								"webhook"
							]
						},
						"description": "Recebe webhook do WhatsApp Business API\n\n**Headers obrigatórios:**\n- `x-account-id`: UUID da conta de mensageria"
					},
					"response": []
				},
