									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Webhook processed\", function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('success');",
									"    pm.expect(jsonData.success).to.be.true;",
									"});",
									"",
									"console.log(\"✅ Webhook processado com sucesso!\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							},
							{
								"key": "x-account-id",
								"value": "{{messaging_account_id}}",
								"type": "text",
								"description": "UUID da conta de mensageria"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"msg_123456789\",\n  \"from\": \"5511999999999\",\n  \"to\": \"5511888888888\",\n  \"body\": \"Olá! Esta é uma mensagem de teste do UAZAPI\",\n  \"timestamp\": 1642684800,\n  \"isGroup\": false,\n  \"pushName\": \"João Silva\",\n  \"type\": \"text\"\n}"
						},
						"url": {
							"raw": "{{functions_url}}/messaging/webhook",
							"host": [
								"{{functions_url}}"
							],
							"path": [
								"messaging",
								"webhook"
							]
						},
						"description": "Recebe webhook do UAZAPI e processa mensagem automaticamente\n\n**Headers obrigatórios:**\n- `x-account-id`: UUID da conta de mensageria\n\n**O que acontece:**\n1. Webhook recebido e normalizado\n2. Contato criado automaticamente (se não existir)\n3. Estatísticas atualizadas\n4. Retorna sucesso"
					},
					"response": []
				},
