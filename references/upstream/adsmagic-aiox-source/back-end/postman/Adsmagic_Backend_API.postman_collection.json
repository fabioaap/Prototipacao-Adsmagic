	"item": [
		{
			"name": "🔐 Authentication",
			"item": [
				{
					"name": "Login (Sign In)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.access_token) {",
									"        pm.environment.set(\"jwt_token\", response.access_token);",
									"        pm.environment.set(\"refresh_token\", response.refresh_token);",
									"        pm.environment.set(\"user_id\", response.user.id);",
									"        console.log(\"✅ Token salvo com sucesso!\");",
									"        console.log(\"User ID:\", response.user.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "apikey",
								"value": "{{anon_key}}",
								"type": "text",
								"description": "Chave anônima do Supabase (obrigatória para Auth API)"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"teste@example.com\",\n  \"password\": \"SenhaSegura123!\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/v1/token?grant_type=password",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"v1",
								"token"
							],
							"query": [
								{
									"key": "grant_type",
									"value": "password"
								}
							]
						},
						"description": "Fazer login e obter JWT token\n\n⚠️ IMPORTANTE: A API de autenticação do Supabase requer o header `apikey` com a chave anônima do projeto."
					},
					"response": []
				},
